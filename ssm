#!/usr/bin/env bash
set -euo pipefail

# --- Colour support (disabled when not writing to a terminal) ---
if [[ -t 2 ]]; then
  _reset=$'\033[0m'
  _bold=$'\033[1m'
  _red=$'\033[31m'
  _green=$'\033[32m'
  _yellow=$'\033[33m'
  _cyan=$'\033[36m'
  _dim=$'\033[2m'
else
  _reset="" _bold="" _red="" _green="" _yellow="" _cyan="" _dim=""
fi

# Semantic output helpers — these give meaning to the colours so we don't
# scatter escape codes throughout the script.

die()     { echo -e "${_red}${_bold}Error:${_reset} $1" >&2; exit 1; }
info()    { echo "${_cyan}▸${_reset} $1" >&2; }
heading() { echo "${_bold}$1${_reset}" >&2; }
value()   { printf '%s' "${_green}$1${_reset}"; }
instance(){ printf '%s' "${_cyan}$1${_reset}"; }
label()   { printf '%s' "${_dim}$1${_reset}${_green}$2${_reset}"; }
dim()     { printf '%s' "${_dim}$1${_reset}"; }
arg()     { printf '%s' "${_yellow}$1${_reset}"; }

usage() {
  cat <<EOF
${_bold}Usage:${_reset} ssm [ssh] -p <profile> [-r <region>] (-i <instance-id> | -t <app[,stack[,stage]]>) [--newest | --oldest]

${_bold}Required:${_reset}
  -p, --profile <profile>       The AWS profile name to use for authenticating this execution

${_bold}Optional:${_reset}
  -r, --region <region>         AWS region (default: eu-west-1)

${_bold}One of these must be provided:${_reset}
  -i, --instance <instance-id>  Connect directly to this EC2 instance
  -t, --tags <app[,stack[,stage]]>
                                Discover instance by App, Stack, Stage tags

${_bold}Instance discovery flags${_reset} (when -t finds multiple matching instances):
  --newest                      Select the most recently launched instance
  --oldest                      Select the least recently launched instance
EOF
  exit 1
}

# --- Defaults ---
PROFILE=""
REGION="eu-west-1"
INSTANCE=""
TAGS=""
SORT_ORDER="" # "newest" or "oldest"

# --- Optionally consume 'ssh' for compatibility with ssm-scala's ssh subcommand ---
if [[ $# -gt 0 ]] && [[ "$1" == "ssh" ]]; then
  shift
fi

if [[ $# -eq 0 ]]; then
  usage
fi

# --- Parse arguments ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--profile)
      [[ $# -ge 2 ]] || die "Missing value for $(arg "$1")"
      PROFILE="$2"; shift 2 ;;
    -r|--region)
      [[ $# -ge 2 ]] || die "Missing value for $(arg "$1")"
      REGION="$2"; shift 2 ;;
    -i|--instance)
      [[ $# -ge 2 ]] || die "Missing value for $(arg "$1")"
      INSTANCE="$2"; shift 2 ;;
    -t|--tags)
      [[ $# -ge 2 ]] || die "Missing value for $(arg "$1")"
      TAGS="$2"; shift 2 ;;
    --newest)
      SORT_ORDER="newest"; shift ;;
    --oldest)
      SORT_ORDER="oldest"; shift ;;
    -h|--help)
      usage ;;
    *)
      die "Unknown argument: $(arg "$1")" ;;
  esac
done

# --- Validate required arguments ---
[[ -n "$PROFILE" ]] || die "$(arg "-p") / $(arg "--profile") is required"
[[ -n "$INSTANCE" || -n "$TAGS" ]] || die "Either $(arg "--instance") or $(arg "--tags") must be provided"
[[ -z "$INSTANCE" || -z "$TAGS" ]] || die "Cannot specify both $(arg "--instance") and $(arg "--tags")"

# --- Resolve instance ID from tags if needed ---
if [[ -z "$INSTANCE" ]]; then
  # Parse comma-separated tags into App, Stack, Stage
  IFS=',' read -ra TAG_PARTS <<< "$TAGS"
  TAG_COUNT=${#TAG_PARTS[@]}

  if [[ $TAG_COUNT -lt 1 || $TAG_COUNT -gt 3 ]]; then
    die "Tags must have 1 to 3 comma-separated values (App[,Stack[,Stage]])"
  fi

  # Build the EC2 describe-instances filter
  FILTERS=("Name=tag:App,Values=${TAG_PARTS[0]}")
  if [[ $TAG_COUNT -ge 2 ]]; then
    FILTERS+=("Name=tag:Stack,Values=${TAG_PARTS[1]}")
  fi
  if [[ $TAG_COUNT -ge 3 ]]; then
    FILTERS+=("Name=tag:Stage,Values=${TAG_PARTS[2]}")
  fi
  # Only look at running instances
  FILTERS+=("Name=instance-state-name,Values=running")

  SEARCH_DESC="$(label "App=" "${TAG_PARTS[0]}")"
  if [[ $TAG_COUNT -ge 2 ]]; then
    SEARCH_DESC+=", $(label "Stack=" "${TAG_PARTS[1]}")"
  fi
  if [[ $TAG_COUNT -ge 3 ]]; then
    SEARCH_DESC+=", $(label "Stage=" "${TAG_PARTS[2]}")"
  fi
  info "Discovering instances matching ${SEARCH_DESC} ..."

  # Use JMESPath to extract and flatten fields directly, returning tab-separated text.
  # Each row: InstanceId \t LaunchTime \t Name \t App \t Stack \t Stage
  JMESPATH="Reservations[].Instances[].["
  JMESPATH+="InstanceId,"
  JMESPATH+="LaunchTime,"
  JMESPATH+="(Tags[?Key=='Name'].Value)[0] || '-',"
  JMESPATH+="(Tags[?Key=='App'].Value)[0] || '-',"
  JMESPATH+="(Tags[?Key=='Stack'].Value)[0] || '-',"
  JMESPATH+="(Tags[?Key=='Stage'].Value)[0] || '-'"
  JMESPATH+="]"

  RESULT=$(aws ec2 describe-instances \
    --profile "$PROFILE" \
    --region "$REGION" \
    --filters "${FILTERS[@]}" \
    --query "$JMESPATH" \
    --output text) || die "Failed to query EC2 instances"

  if [[ -z "$RESULT" ]]; then
    echo ""
    die "No running instances found using profile $(value "$PROFILE")"
  fi

  # Parse rows into arrays
  INSTANCE_IDS=()
  LAUNCH_TIMES=()
  NAMES=()
  APPS=()
  STACKS=()
  STAGES=()

  while IFS=$'\t' read -r id launch name app stack stage; do
    INSTANCE_IDS+=("$id")
    LAUNCH_TIMES+=("$launch")
    NAMES+=("$name")
    APPS+=("$app")
    STACKS+=("$stack")
    STAGES+=("$stage")
  done <<< "$RESULT"

  INSTANCE_COUNT=${#INSTANCE_IDS[@]}

  # Convert an ISO-8601 timestamp to a human-friendly relative age.
  # Works with both GNU date (Linux) and BSD date (macOS).
  human_age() {
    local timestamp="$1"
    local launch_epoch now_epoch seconds

    # Try GNU date first, fall back to BSD date
    if launch_epoch=$(date -d "$timestamp" +%s 2>/dev/null); then
      : # GNU date worked
    else
      # BSD date: strip fractional seconds and normalise +00:00 → +0000
      local cleaned
      cleaned=$(echo "$timestamp" | sed -E 's/\.[0-9]+//; s/:([0-9]{2})$/\1/')
      launch_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S%z" "$cleaned" +%s 2>/dev/null) \
        || launch_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$cleaned" +%s 2>/dev/null) \
        || { echo "$timestamp"; return; }
    fi

    now_epoch=$(date +%s)
    seconds=$(( now_epoch - launch_epoch ))

    if   (( seconds >= 86400 )); then echo "$(( seconds / 86400 ))d ago"
    elif (( seconds >= 3600  )); then echo "$(( seconds / 3600  ))h ago"
    elif (( seconds >= 60    )); then echo "$(( seconds / 60    ))m ago"
    else                              echo "${seconds}s ago"
    fi
  }

  if [[ "$INSTANCE_COUNT" -eq 1 ]]; then
    INSTANCE="${INSTANCE_IDS[0]}"
  else
    # Multiple instances found
    if [[ -z "$SORT_ORDER" ]]; then
      echo "" >&2
      heading "Multiple instances found:"
      for (( idx=0; idx<INSTANCE_COUNT; idx++ )); do
        age=$(human_age "${LAUNCH_TIMES[$idx]}")
        if [[ "${NAMES[$idx]}" != "-" ]]; then
          echo "  $(instance "${INSTANCE_IDS[$idx]}")  ${NAMES[$idx]}" >&2
        else
          echo "  $(instance "${INSTANCE_IDS[$idx]}")  $(dim "-")" >&2
        fi
        echo "    $(label "App=" "${APPS[$idx]}") $(label "Stack=" "${STACKS[$idx]}") $(label "Stage=" "${STAGES[$idx]}")  $(label "launched " "$age")" >&2
      done
      echo "" >&2
      die "Use $(arg "--newest") or $(arg "--oldest") to automatically select an instance\n       or use $(arg "-i") / $(arg "--instance") to specify an instance directly"
    fi

    # Sort by launch time (lexicographic sort works for ISO-8601 timestamps)
    # Build "launch_time<TAB>index" lines, sort them, pick first or last
    sorted_indices=()
    while IFS=$'\t' read -r _ idx; do
      sorted_indices+=("$idx")
    done < <(
      for (( idx=0; idx<INSTANCE_COUNT; idx++ )); do
        printf '%s\t%d\n' "${LAUNCH_TIMES[$idx]}" "$idx"
      done | sort -t$'\t' -k1
    )

    if [[ "$SORT_ORDER" == "newest" ]]; then
      pick=${sorted_indices[${#sorted_indices[@]}-1]}
    elif [[ "$SORT_ORDER" == "oldest" ]]; then
      pick=${sorted_indices[0]}
    else
      die "Unexpected sort order: $(arg "$SORT_ORDER")"
    fi
    INSTANCE="${INSTANCE_IDS[$pick]}"
  fi

  info "Resolved instance: $(instance "$INSTANCE")"
fi

# --- Start SSM session ---
info "Starting SSM session to $(instance "$INSTANCE") $(dim "(profile=${PROFILE}, region=${REGION})")"
exec aws ssm start-session \
  --target "$INSTANCE" \
  --profile "$PROFILE" \
  --region "$REGION"
